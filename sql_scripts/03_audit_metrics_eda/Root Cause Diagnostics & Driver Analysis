-- CHAP 3: Root Cause Diagnostics & Driver Analysis
--------------------------------------------------------------------------------

-- 1. Top lý do cụ thể khiến khách hàng rời bỏ dịch vụ
SELECT
    churn_category AS "Churn Category",
    churn_reason AS "Churn Reason",
    COUNT(*) AS "Customers Lost",
    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2) AS "% of Total Churn",
    ROUND(AVG(monthly_charge), 2) AS "Avg Monthly Charges",
    ROUND(AVG(cltv), 0) AS "Avg CLTV",
    ROUND(AVG(tenure_in_months), 1) AS "Avg Tenure (Months)",
    ROUND(AVG(satisfaction_score), 2) AS "Avg Satisfaction Score"
FROM vw_churn_master
WHERE churn_value = 1
    AND churn_reason IS NOT NULL
GROUP BY churn_category, churn_reason
ORDER BY "Customers Lost" DESC
LIMIT 7; -- Giữ nguyên mốc Top 7 dòng cao nhất giống script của bạn


-- 2. Phân tích sâu: Dịch vụ Internet nào đang có tỷ lệ rời bỏ cao?
SELECT
    internet_type AS "Internet Type",
    COUNT(*) AS "Total Customers",
    SUM(churn_value) AS "Churned Customers",
    ROUND(AVG(churn_value::NUMERIC) * 100, 2) AS "Churn Rate (%)",
    ROUND(AVG(monthly_charge), 2) AS "Avg Monthly Charges",
    ROUND(AVG(CASE WHEN churn_value = 1 THEN monthly_charge END), 2) AS "Avg Monthly Charges (Churned)",
    ROUND(AVG(satisfaction_score), 2) AS "Avg Satisfaction Score",
    ROUND(AVG(tenure_in_months), 1) AS "Avg Tenure (Months)"
FROM vw_churn_master
GROUP BY internet_type
ORDER BY "Churn Rate (%)" DESC;


-- 3. Phân bổ số lượng dịch vụ đi kèm (Addon Distribution) của khách hàng
WITH service_addons AS (
    SELECT *,
        ( (online_security = 'Yes')::INT + 
          (online_backup = 'Yes')::INT + 
          (device_protection_plan = 'Yes')::INT + 
          (premium_tech_support = 'Yes')::INT + 
          (streaming_tv = 'Yes')::INT + 
          (streaming_movies = 'Yes')::INT + 
          (streaming_music = 'Yes')::INT  
        ) AS addon_count
    FROM vw_churn_master
)
SELECT 
    addon_count AS "Number of Addons",
    COUNT(*) AS "Total Customers",
    SUM(churn_value) AS "Churned Customers",
    ROUND(AVG(churn_value::NUMERIC) * 100, 2) AS "Churn Rate (%)"
FROM service_addons
GROUP BY addon_count
ORDER BY addon_count ASC;


-- 4. Ma trận Nguy cơ: Sự kết hợp giữa Loại Internet và Nhóm Addon (Danger Zone Analysis)
WITH service_addons AS (
    SELECT *,
        ( (online_security = 'Yes')::INT + 
          (online_backup = 'Yes')::INT + 
          (device_protection_plan = 'Yes')::INT + 
          (premium_tech_support = 'Yes')::INT + 
          (streaming_tv = 'Yes')::INT + 
          (streaming_movies = 'Yes')::INT + 
          (streaming_music = 'Yes')::INT  
        ) AS addon_count
    FROM vw_churn_master
)
SELECT
    internet_type AS "Internet Type",
    CASE
        WHEN addon_count = 0             THEN '0 — No Addons'
        WHEN addon_count BETWEEN 1 AND 2 THEN '1–2 Addons'
        ELSE '3+ Addons'
    END AS "Addon Tier",
    COUNT(*) AS "Total Customers",
    SUM(churn_value) AS "Churned Customers",
    ROUND(AVG(churn_value::NUMERIC) * 100, 2) AS "Churn Rate (%)",
    ROUND(AVG(monthly_charge), 2) AS "Avg Monthly Charges",
    ROUND(AVG(satisfaction_score), 2) AS "Avg Satisfaction Score"
FROM service_addons
WHERE internet_type IS NOT NULL
GROUP BY internet_type, 
         CASE
             WHEN addon_count = 0             THEN '0 — No Addons'
             WHEN addon_count BETWEEN 1 AND 2 THEN '1–2 Addons'
             ELSE '3+ Addons'
         END
ORDER BY "Internet Type", "Churn Rate (%)" DESC;
